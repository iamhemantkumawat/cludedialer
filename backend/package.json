{
  "name": "cludedialer-backend",
  "version": "2.0.0",
  "description": "CyberX AutoDialer PostgreSQL backend",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --ignore-watch node_modules --watch src src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "db:init": "node scripts/init-db.cjs",
    "db:import-legacy": "node scripts/import-legacy-sqlite.cjs"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.7",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.7",
    "@nestjs/platform-express": "^11.0.7",
    "@nestjs/platform-socket.io": "^11.0.7",
    "@nestjs/websockets": "^11.0.7",
    "asterisk-manager": "^0.1.11",
    "better-sqlite3": "^12.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.3",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  }
}

PORT=3001

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=autodialer
PG_USER=autodialer
PG_PASSWORD=changeme

# Asterisk AMI
AMI_HOST=localhost
AMI_PORT=5038
AMI_USER=autodialer_bot
AMI_SECRET=changeme123

# Asterisk Docker container name (for audio file copy)
ASTERISK_CONTAINER=local-asterisk

# Dialplan context for autodialer
ASTERISK_CONTEXT=autodialer

# MagnusBilling API integration
MAGNUS_API_KEY=your-magnus-api-key
MAGNUS_API_SECRET=your-magnus-api-secret
MAGNUS_PUBLIC_URL=https://your-magnus-domain.com/portal

# Google Cloud TTS API key (for high-quality voice synthesis)
# Get it at: https://console.cloud.google.com/apis/credentials
# Enable "Cloud Text-to-Speech API" first
GOOGLE_TTS_API_KEY=your-google-cloud-tts-api-key
